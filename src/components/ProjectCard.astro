---
import Icons from './Icons.astro';
import ProjectGallery from './ProjectGallery.astro';
import type { Project } from '../data/profile';
import { resolveUrl, isPlaceholder } from '../data/profile';

interface Props {
  project: Project;
}

const { project } = Astro.props;

const accentGlow = {
  cyan: 'group-hover:shadow-[0_0_40px_rgba(94,235,255,0.12)]',
  pink: 'group-hover:shadow-[0_0_40px_rgba(255,79,216,0.12)]',
  violet: 'group-hover:shadow-[0_0_40px_rgba(155,92,255,0.12)]',
};
---

<article
  class={`group gradient-border reveal overflow-hidden rounded-3xl transition-shadow duration-300 ${accentGlow[project.accent]}`}
  aria-labelledby={`project-${project.id}-title`}
>
  <ProjectGallery
    projectId={project.id}
    projectName={project.name}
    images={project.images}
  />

  <div class="relative p-6 sm:p-8 lg:p-10">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <h3 id={`project-${project.id}-title`} class="text-2xl font-bold text-text sm:text-3xl">
          {project.name}
        </h3>
        <p class="mt-2 text-sm font-medium text-muted sm:text-base">{project.role}</p>
      </div>
      <div class="flex flex-wrap gap-2" aria-label="Project tags">
        {project.tags.map((tag) => (
          <span class="chip text-xs sm:text-sm">{tag}</span>
        ))}
      </div>
    </div>

    <p class="mt-5 text-lg font-medium leading-relaxed text-text/90">{project.pitch}</p>

    <p class="mt-4 text-sm font-semibold text-cyan">{project.proves}</p>

    <ul class="mt-6 space-y-3" role="list">
      {project.bullets.map((bullet) => (
        <li class="flex gap-3 text-base leading-relaxed text-muted">
          <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-gradient-to-r from-cyan to-pink" aria-hidden="true"></span>
          <span>{bullet}</span>
        </li>
      ))}
    </ul>

    <div class="mt-8 flex flex-wrap gap-2" role="list" aria-label="Project metrics">
      {project.metrics.map((metric) => (
        <span class="chip border-cyan/20 bg-cyan/5 text-text/80">{metric}</span>
      ))}
    </div>

    <div class="mt-8 flex flex-wrap gap-3">
      {project.links.map((link) => {
        const placeholder = isPlaceholder(link.url);
        return (
          <a
            href={resolveUrl(link.url)}
            class="btn-secondary text-sm"
            target={placeholder ? undefined : '_blank'}
            rel={placeholder ? undefined : 'noopener noreferrer'}
            aria-label={placeholder ? `${link.label} (link pending)` : link.label}
            data-placeholder={placeholder ? 'true' : undefined}
          >
            <Icons name={link.type === 'details' ? 'external' : link.type} class="w-4 h-4" />
            {link.label}
          </a>
        );
      })}
    </div>
  </div>
</article>
