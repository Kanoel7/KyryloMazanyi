---
interface Props {
  title: string;
  subtitle?: string;
  id?: string;
}

const { title, subtitle, id } = Astro.props;
---

<div class="reveal mb-12 sm:mb-14">
  {id && <span id={id} class="sr-only">{title}</span>}
  <h2 class="text-3xl font-bold tracking-tight text-text sm:text-4xl lg:text-[2.5rem] lg:leading-tight">
    {title}
  </h2>
  {subtitle && (
    <p class="mt-3 max-w-2xl text-lg text-muted leading-relaxed">{subtitle}</p>
  )}
  <div class="mt-5 h-px w-16 bg-gradient-to-r from-cyan to-pink" aria-hidden="true"></div>
</div>
