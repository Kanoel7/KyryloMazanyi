---
interface Props {
  value: string;
  label: string;
  centered?: boolean;
}

const { value, label, centered = false } = Astro.props;
const isLongValue = value.length > 8;
---

<div
  class:list={[
    'glass-card glass-card-hover reveal h-full rounded-2xl p-4 sm:p-5',
    centered && 'text-center',
  ]}
>
  <p
    class:list={[
      'font-bold tracking-tight text-text',
      isLongValue ? 'text-lg sm:text-xl lg:text-2xl' : 'text-2xl sm:text-3xl',
    ]}
  >
    {value}
  </p>
  <p class="mt-1.5 text-pretty text-xs font-medium leading-snug text-muted sm:text-sm">
    {label}
  </p>
</div>
