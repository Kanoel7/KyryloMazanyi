---
import Icons from './Icons.astro';
import { profile, resolveUrl, isPlaceholder, getHeaderSocialLinks } from '../data/profile';

const headerSocial = getHeaderSocialLinks();
const cvUrl = profile.cvUrl ?? '#';
const cvPlaceholder = profile.cvUrl === null;
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-white/5 bg-bg/70 backdrop-blur-xl"
  role="banner"
>
  <div class="container-main flex h-16 items-center justify-between gap-4 sm:h-[4.5rem]">
    <a
      href="#top"
      class="shrink-0 text-sm font-bold tracking-[0.2em] text-text transition-colors hover:text-cyan sm:text-base"
      aria-label={`${profile.name} — home`}
    >
      <span class="hidden sm:inline">KYRYLO MAZANYI</span>
      <span class="sm:hidden">{profile.shortName}</span>
    </a>

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Main navigation">
      {profile.nav.map((item) => (
        <a
          href={item.href}
          class="rounded-lg px-3 py-2 text-sm font-medium text-muted transition-colors hover:text-cyan"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-1 sm:gap-2">
      <div class="hidden items-center gap-0.5 md:flex">
        {headerSocial.map((link) => (
          <a
            href={resolveUrl(link.url)}
            class="rounded-lg p-2.5 text-muted transition-colors hover:text-cyan"
            target={isPlaceholder(link.url) ? undefined : '_blank'}
            rel={isPlaceholder(link.url) ? undefined : 'noopener noreferrer'}
            aria-label={isPlaceholder(link.url) ? `${link.label} (link pending)` : link.label}
            data-placeholder={isPlaceholder(link.url) ? 'true' : undefined}
          >
            <Icons name={link.icon} class="w-5 h-5" />
          </a>
        ))}
        <a
          href={`mailto:${profile.email}`}
          class="rounded-lg p-2.5 text-muted transition-colors hover:text-cyan"
          aria-label="Email"
        >
          <Icons name="email" class="w-5 h-5" />
        </a>
        <a
          href={cvUrl}
          class="btn-ghost hidden xl:inline-flex"
          download={cvPlaceholder ? undefined : ''}
          aria-label={cvPlaceholder ? 'Download CV (file pending)' : 'Download CV'}
          data-placeholder={cvPlaceholder ? 'true' : undefined}
        >
          <Icons name="cv" class="w-4 h-4" />
          CV
        </a>
      </div>

      <button
        type="button"
        class="menu-toggle relative inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg text-muted transition-colors hover:text-cyan lg:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        id="menu-toggle"
        data-state="closed"
      >
        <Icons name="menu" class="menu-toggle-open h-6 w-6" />
        <Icons name="close" class="menu-toggle-close h-6 w-6" />
      </button>
    </div>
  </div>

  <nav
    id="mobile-menu"
    class="hidden border-t border-white/5 bg-bg/95 backdrop-blur-xl lg:hidden"
    aria-label="Mobile navigation"
  >
    <div class="container-main flex flex-col gap-1 py-4">
      {profile.nav.map((item) => (
        <a
          href={item.href}
          class="mobile-nav-link rounded-xl px-4 py-3 text-base font-medium text-muted transition-colors hover:bg-white/5 hover:text-cyan"
        >
          {item.label}
        </a>
      ))}
      <div class="mt-3 flex flex-wrap gap-2 border-t border-white/5 pt-4">
        {headerSocial.map((link) => (
          <a
            href={resolveUrl(link.url)}
            class="btn-secondary text-sm"
            target={isPlaceholder(link.url) ? undefined : '_blank'}
            rel={isPlaceholder(link.url) ? undefined : 'noopener noreferrer'}
            aria-label={isPlaceholder(link.url) ? `${link.label} (link pending)` : link.label}
            data-placeholder={isPlaceholder(link.url) ? 'true' : undefined}
          >
            <Icons name={link.icon} class="w-4 h-4" />
            {link.label}
          </a>
        ))}
        <a href={`mailto:${profile.email}`} class="btn-secondary text-sm">
          <Icons name="email" class="w-4 h-4" />
          Email
        </a>
        <a
          href={cvUrl}
          class="btn-secondary text-sm"
          download={cvPlaceholder ? undefined : ''}
          aria-label={cvPlaceholder ? 'Download CV (file pending)' : 'Download CV'}
        >
          <Icons name="cv" class="w-4 h-4" />
          Download CV
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const navLinks = document.querySelectorAll('.mobile-nav-link');

  function setMenuState(open: boolean) {
    if (!toggle || !menu) return;
    menu.classList.toggle('hidden', !open);
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    toggle.setAttribute('data-state', open ? 'open' : 'closed');
  }

  function closeMenu() {
    setMenuState(false);
  }

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('data-state') === 'open';
    setMenuState(!isOpen);
  });

  navLinks.forEach((link) => link.addEventListener('click', closeMenu));
</script>
